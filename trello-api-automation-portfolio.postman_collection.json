        {
          "name": "ERR-02 - Invalid Token Access",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Validar el código de estado de seguridad\r",
                  "pm.test(\"Status code es 401 Unauthorized\", function () {\r",
                  "    pm.response.to.have.status(401);\r",
                  "});\r",
                  "\r",
                  "// 2. Validar el mensaje de error en formato texto (Raw)\r",
                  "pm.test(\"El cuerpo de respuesta contiene 'invalid app token'\", function () {\r",
                  "    pm.expect(pm.response.text()).to.include(\"invalid app token\");\r",
                  "});\r",
                  "\r",
                  "// 3. Validar que la respuesta NO sea un JSON (Prueba de consistencia)\r",
                  "pm.test(\"La respuesta no es un objeto JSON\", function () {\r",
                  "    try {\r",
                  "        pm.response.json();\r",
                  "        // Si logra convertirlo a JSON, algo cambió, queremos que el test falle\r",
                  "        pm.expect.fail(\"Se esperaba texto plano, pero se recibió un JSON\");\r",
                  "    } catch (e) {\r",
                  "        // Si da error al intentar parsear JSON, es que es texto plano. ¡Éxito!\r",
                  "        pm.expect(true).to.be.true;\r",
                  "    }\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
